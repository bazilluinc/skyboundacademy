{
  "name": "skybound-academy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:full": "npm run build && wrangler pages dev ./dist",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "wrangler pages deploy ./dist",
    "db:push": "wrangler d1 execute skyboundacademy_db --file=./schema.sql --remote",
    "db:local": "wrangler d1 execute skyboundacademy_db --file=./schema.sql --local"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20231121.0",
    "@rollup/rollup-win32-x64-msvc": "^4.57.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@cloudflare/pages-plugin-cloudflare-access": "^1.0.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.2.0",
    "vite": "^5.0.0",
    "wrangler": "^3.17.0"
  }
}